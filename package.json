{
  "name": "auren",
  "version": "1.0.0",
  "private": true,
  "main": "expo/AppEntry",
  "scripts": {
    "start": "expo start",
    "start:clear": "expo start --clear",
    "start:tunnel": "expo start --tunnel",
    "start:tunnel:clear": "expo start --tunnel --clear",
    "git:fetch": "git fetch origin",
    "git:reset": "git reset --hard origin/main",
    "sync:main": "git fetch origin && git reset --hard origin/main",
    "sync:start": "git fetch origin && git reset --hard origin/main && npm run start:tunnel:clear",
    "install:clean": "npm install",
    "repair:start": "npm install && npm run start:tunnel:clear",
    "ios": "expo start --ios",
    "android": "expo start --android",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@supabase/supabase-js": "^2.79.0",
    "expo": "~54.0.0",
    "expo-constants": "~18.0.10",
    "expo-device": "~8.0.9",
    "expo-haptics": "~15.0.7",
    "expo-linear-gradient": "~15.0.7",
    "expo-media-library": "~18.2.0",
    "expo-notifications": "~0.32.12",
    "expo-status-bar": "~3.0.8",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-svg": "^15.12.1",
    "react-native-url-polyfill": "^2.0.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "babel-preset-expo": "~54.0.0",
    "typescript": "~5.9.2"
  }
}
